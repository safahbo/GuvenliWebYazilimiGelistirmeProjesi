# SentinelStaff VMS - Environment Variable Template
# UYARI: Bu dosyayı '.env' olarak kopyalayın ve değerleri kendi ortamınıza göre doldurun.
# Gerçek '.env' dosyasını ASLA git reposuna commitlemeyin.

# --- Core Application Settings ---
PORT=3000
NODE_ENV=development

# --- Database Settings ---
# Lokal geliştirme için: ./vms.sqlite
# Docker ortamı için: /app/db_data/vms.sqlite
DB_PATH=./vms.sqlite

# --- Security & Auth (Gelecek fazlar için taslak) ---
# JWT_SECRET=your_super_secret_key_here
# RATE_LIMIT_WINDOW_MS=900000
